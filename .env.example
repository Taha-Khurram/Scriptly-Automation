# Copy to .env and adjust. Never commit the real .env.

# Base URL of the running Scriptly Flask app (start it from ../FYP-main: python app.py)
BASE_URL=http://localhost:5000

# Public site slug used by public-site tests (self-skips if the site 404s)
SITE_SLUG=demo

# Global default timeout for actions/navigation/expect, in milliseconds
DEFAULT_TIMEOUT=30000

# --- Tier 2 (authenticated) tests only. Leave blank to skip them. ---
# Must be a real Gmail account that exists in the app's Firebase project.
TEST_EMAIL=
TEST_PASSWORD=

# --- Presentation (headed debugging / demos). All optional. ---
# Run the browser visibly (true) instead of headless. Always headless in CI.
HEADED=false
# Use an installed browser instead of bundled Chromium, e.g. "chrome" or "msedge".
BROWSER_CHANNEL=
# Slow every action by N ms so a headed run is watchable (e.g. 500).
SLOW_MO=0
# Launch the window maximized (drops the fixed viewport).
MAXIMIZED=false
WINDOW_WIDTH=1920
WINDOW_HEIGHT=1080
