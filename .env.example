# Copy to .env and adjust. Never commit the real .env.

# Base URL of the running Scriptly Flask app (start it from ../FYP-main: python app.py)
BASE_URL=http://localhost:5000

# Run browsers headless (true) or visible (false)
HEADLESS=true

# Global default timeout for actions/navigation, in milliseconds
DEFAULT_TIMEOUT=30000

# Public site slug used by public-site tests (self-skips if the site 404s)
SITE_SLUG=demo

# --- Tier 2 (authenticated) tests only. Leave blank to skip them. ---
# Must be a real Gmail account that exists in the app's Firebase project.
TEST_EMAIL=
TEST_PASSWORD=
